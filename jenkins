pipeline {
    agent any

    stages {

        stage('Code') {
            steps {
                echo 'Fetching code from repository'
                git url:"https://github.com/gouravlande/Dockerized-Spring-Boot-App-with-MySQL.git", branch:"main"
                // git 'https://github.com/your-repo.git'
            }
        }

        stage('Build') {
            steps {
                sh "docker build -t  gouravlande/springboot-mysql-app:1.0 ."
                echo 'Building the application'
                // sh 'mvn clean install'
            }
        }
        
         stage('Test') {
            steps {
                echo 'Running tests'
                //sh 'mvn test'
            }
        }
        stage('Deploy') {
    steps {
        script {
            echo 'Deploying application'

            sh 'docker compose down || true'
            sh 'docker compose up -d --build'

            sh '''
            for i in $(seq 1 30); do
              echo "Checking app..."

              if curl -L http://localhost:9090/login > /dev/null; then
                echo "App is running ✅"
                exit 0
              fi

              sleep 5
            done

            echo "App failed ❌"
            exit 1
            '''
        }
    }
}



}

    post {
        success {
            echo 'Deployment Successful 🚀'
        }
        failure {
            echo 'Pipeline Failed ❌'
        }
    }
}
